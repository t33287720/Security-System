# ============================================================
# GAIsecurity — Environment Configuration Template
# cp .env.example .env  →  fill in the values  →  docker compose up -d
# ============================================================

# ── Elasticsearch ────────────────────────────────────────────
ES_PASS=changeme

# ── MySQL ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme

# ── Ollama (LLM inference) ───────────────────────────────────
# Local:  http://127.0.0.1:11434/api/generate
# Remote: http://<gpu-server-ip>:8083/api/generate
OLLAMA_URL=http://127.0.0.1:8083/api/generate

# ── Zeek network interface ───────────────────────────────────
# Run `ip link` to find the right interface name (e.g. eth0, ens3, enp3s0)
ZEEK_IFACE=eth0

# ── ipset names (usually no need to change) ──────────────────
IPSET_NAME=blacklistv4
IPSET_FULL_NAME=blackfulllistv4

# ── Host IPs to exclude from blocking ───────────────────────
# Comma-separated, e.g. 192.168.1.1,192.168.1.2
MANUAL_IPS=

# ── Exposed ports (change if there are conflicts) ────────────
WEB_PORT=80
KIBANA_PORT=5601

# ── Memory tuning ─────────────────────────────────────────────
# ES heap: set min=max, recommend 25-50% of total RAM, max 30g
# ES container limit should be 2× heap (ES also uses OS page cache)
# Logstash heap: 512m is sufficient for light traffic
#
# RAM guide:
#   8 GB  server → ES_HEAP=2g  ES_MEM_LIMIT=4g  LS_HEAP=256m
#   16 GB server → ES_HEAP=4g  ES_MEM_LIMIT=8g  LS_HEAP=512m  (default)
#   32 GB server → ES_HEAP=8g  ES_MEM_LIMIT=16g LS_HEAP=1g
ES_HEAP=4g
ES_MEM_LIMIT=8g
LS_HEAP=512m
