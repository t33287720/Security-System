# ============================================================
# Security System — Environment Configuration Template
# cp .env.example .env  →  fill in the values  →  docker compose up -d
# ============================================================

# ── Elasticsearch (宿主機 host systemctl) ─────────────────────
# elastic 帳號密碼（ES 安裝時設定）
ES_PASS=changeme

# Worker container 用 host network mode，直連 localhost
ES_HOST_WORKER=https://localhost:9200
# Web container 透過 Docker bridge gateway 連回宿主機
ES_HOST_WEB=https://host.docker.internal:9200

# ── MariaDB (宿主機，多產品共用) ──────────────────────────────
# 使用專用 Container 帳號（限授權 CCT_Security 資料庫）
MYSQL_USER=Container
MYSQL_PASS=changeme

# ── Ollama (LLM inference) ────────────────────────────────────
# 本機：http://127.0.0.1:11434/api/generate
# 遠端：http://<gpu-server-ip>:8083/api/generate
OLLAMA_URL=http://127.0.0.1:8083/api/generate

# ── RAG 向量嵌入服務（選填，rag_store.py 使用）────────────────
EMBED_URL=http://127.0.0.1:8006/embed

# ── Zeek 監聽網卡（deploy.sh 設定 systemd service 時使用）──────
# 用 `ip link` 確認正確的網卡名稱（例：eth0, ens3, enp3s0）
ZEEK_IFACE=eth0

# ── ipset 集合名稱（通常不需修改）────────────────────────────
IPSET_NAME=blacklistv4
IPSET_FULL_NAME=blackfulllistv4
IPSET_WHITELIST_NAME=whitelistv4

# ── 白名單 IP（不會被封鎖，逗號分隔）──────────────────────────
# 必填：自己的 SSH 來源 IP 及主機對外 IP，避免自我封鎖
# 例：MANUAL_IPS=140.124.32.16,211.72.136.45
MANUAL_IPS=

# ── Web 容器對外 Port ──────────────────────────────────────────
# 視宿主機 port 占用情況調整（nginx 反向代理會轉進此 port）
WEB_PORT=80
