FROM php:8.2-apache

RUN docker-php-ext-install mysqli && a2enmod rewrite

# Set web root to the project directory
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html/GAIsecurity|g' \
    /etc/apache2/sites-available/000-default.conf && \
    echo '<Directory /var/www/html/GAIsecurity>\n    AllowOverride All\n    Require all granted\n</Directory>' \
    >> /etc/apache2/apache2.conf

# Block direct access to api/ directory
RUN echo 'Alias /api /var/www/html/GAIsecurity/api\n<Location /api>\n    Require all denied\n</Location>' \
    >> /etc/apache2/conf-available/gaisec.conf && \
    a2enconf gaisec

COPY . /var/www/html/GAIsecurity/
COPY entrypoint-web.sh /entrypoint-web.sh
RUN chmod +x /entrypoint-web.sh

ENTRYPOINT ["/entrypoint-web.sh"]
