# ── Secrets (never commit) ────────────────────────────────────
.env
config/security_hosts.json
config/security_config.json

# ── DB dumps (contain real data, store in /var/opt/Security-System/) ──
config/mysql/*_dump.sql

# ── Generated / runtime data ──────────────────────────────────
worker/data/
worker/eval/output/

# ── Old archived scripts ──────────────────────────────────────
worker/elk_api_old*.py

# ── Dev / test helpers ────────────────────────────────────────
api_check/
test.php

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*.swp
*.swo
